ENVIRONMENT=development
AUTO_CREATE_TABLES=true
ENABLE_API_DOCS=true

DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=72
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_SECRET_KEY=replace-with-different-strong-secret
REFRESH_TOKEN_TTL_DAYS=14
REFRESH_COOKIE_NAME=quorex_refresh_token
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SAMESITE=lax

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1
FORCE_HTTPS=false
ENABLE_SECURITY_HEADERS=true
LOG_LEVEL=INFO
LOG_JSON=true
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=180
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=10
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.05
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https: ws: wss:; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=
OLLAMA_AUTH_HEADER=Authorization
OLLAMA_AUTH_SCHEME=Bearer
CHAT_ENABLED=true
CHAT_MAX_INPUT_CHARS=2000
CHAT_MAX_OUTPUT_TOKENS=400
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_DAILY_REQUEST_LIMIT=100
ALLOW_NEW_REGISTRATIONS=true
NOVU_API_KEY=
